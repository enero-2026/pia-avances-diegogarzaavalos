{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "Library (Node CommonJS)",
  "extends": "./base.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "Node",
    "target": "ES2022",
    "lib": ["ES2022"],
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "noEmit": false,
    "incremental": false,
    "composite": false,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true
  }
}
